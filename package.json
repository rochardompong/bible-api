{
  "name": "bible-mirror",
  "private": true,
  "version": "1.0.0",
  "description": "YouVersion Bible scraper + Cloudflare Workers API mirror",
  "workspaces": ["scraper", "worker"],
  "scripts": {
    "scraper:build": "pnpm --filter scraper build",
    "scraper:run": "pnpm --filter scraper start",
    "worker:dev": "pnpm --filter worker dev",
    "worker:deploy": "pnpm --filter worker deploy"
  },
  "packageManager": "pnpm@9.0.0"
}
